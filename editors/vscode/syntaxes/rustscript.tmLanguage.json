{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "RustScript",
  "scopeName": "source.rustscript",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#template-literals" },
    { "include": "#numeric-literals" },
    { "include": "#constants" },
    { "include": "#keywords" },
    { "include": "#storage-types" },
    { "include": "#function-declaration" },
    { "include": "#arrow-function" },
    { "include": "#class-declaration" },
    { "include": "#interface-declaration" },
    { "include": "#type-declaration" },
    { "include": "#enum-declaration" },
    { "include": "#import-export" },
    { "include": "#function-call" },
    { "include": "#type-annotation" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.rustscript",
          "match": "//.*$"
        },
        {
          "name": "comment.block.rustscript",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.rustscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.rustscript",
              "match": "\\\\([\\\\\"/bfnrt]|u[0-9a-fA-F]{4}|x[0-9a-fA-F]{2})"
            }
          ]
        },
        {
          "name": "string.quoted.single.rustscript",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.rustscript",
              "match": "\\\\([\\\\\\'bfnrt]|u[0-9a-fA-F]{4}|x[0-9a-fA-F]{2})"
            }
          ]
        }
      ]
    },
    "template-literals": {
      "name": "string.template.rustscript",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "constant.character.escape.rustscript",
          "match": "\\\\([\\\\\"`bfnrt$]|u[0-9a-fA-F]{4}|x[0-9a-fA-F]{2})"
        },
        {
          "name": "meta.template.expression.rustscript",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.template-expression.begin.rustscript" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.template-expression.end.rustscript" }
          },
          "patterns": [
            { "include": "source.rustscript" }
          ]
        }
      ]
    },
    "numeric-literals": {
      "patterns": [
        {
          "name": "constant.numeric.hex.rustscript",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.octal.rustscript",
          "match": "\\b0[oO][0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.binary.rustscript",
          "match": "\\b0[bB][01][01_]*\\b"
        },
        {
          "name": "constant.numeric.float.rustscript",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9][0-9_]*)?\\b"
        },
        {
          "name": "constant.numeric.float.rustscript",
          "match": "\\b[0-9][0-9_]*[eE][+-]?[0-9][0-9_]*\\b"
        },
        {
          "name": "constant.numeric.integer.rustscript",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.rustscript",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.rustscript",
          "match": "\\bfalse\\b"
        },
        {
          "name": "constant.language.null.rustscript",
          "match": "\\bnull\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.rustscript",
          "match": "\\b(if|else|while|for|return|break|continue|switch|case|default)\\b"
        },
        {
          "name": "keyword.control.trycatch.rustscript",
          "match": "\\b(try|catch|finally|throw|throws)\\b"
        },
        {
          "name": "keyword.declaration.rustscript",
          "match": "\\b(function|const|let|type|class|interface|enum)\\b"
        },
        {
          "name": "keyword.async.rustscript",
          "match": "\\b(async|await)\\b"
        },
        {
          "name": "keyword.module.rustscript",
          "match": "\\b(import|export|from)\\b"
        },
        {
          "name": "keyword.operator.new.rustscript",
          "match": "\\bnew\\b"
        },
        {
          "name": "keyword.other.move.rustscript",
          "match": "\\bmove\\b"
        },
        {
          "name": "keyword.other.rust-block.rustscript",
          "match": "\\brust\\b"
        },
        {
          "name": "keyword.other.shared.rustscript",
          "match": "\\bshared\\b"
        },
        {
          "name": "keyword.other.implements.rustscript",
          "match": "\\bimplements\\b"
        },
        {
          "name": "keyword.other.constructor.rustscript",
          "match": "\\bconstructor\\b"
        },
        {
          "name": "keyword.other.this.rustscript",
          "match": "\\bthis\\b"
        },
        {
          "name": "keyword.other.access.rustscript",
          "match": "\\b(private|public)\\b"
        },
        {
          "name": "keyword.control.of.rustscript",
          "match": "\\bof\\b"
        },
        {
          "name": "keyword.other.extends.rustscript",
          "match": "\\bextends\\b"
        },
        {
          "name": "keyword.other.typeof.rustscript",
          "match": "\\b(typeof|instanceof)\\b"
        },
        {
          "name": "keyword.other.as.rustscript",
          "match": "\\bas\\b"
        },
        {
          "name": "keyword.other.in.rustscript",
          "match": "\\bin\\b"
        },
        {
          "name": "keyword.control.spawn.rustscript",
          "match": "\\bspawn\\b"
        },
        {
          "name": "keyword.other.void.rustscript",
          "match": "\\bvoid\\b"
        },
        {
          "name": "keyword.other.self.rustscript",
          "match": "\\bSelf\\b"
        }
      ]
    },
    "storage-types": {
      "patterns": [
        {
          "name": "storage.type.primitive.rustscript",
          "match": "\\b(string|bool|void)\\b"
        },
        {
          "name": "storage.type.numeric.rustscript",
          "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64)\\b"
        },
        {
          "name": "storage.type.collection.rustscript",
          "match": "\\b(Array|Map|Set)\\b"
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "comment": "async function declaration",
          "match": "\\b(async)\\s+(function)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(<)?",
          "captures": {
            "1": { "name": "keyword.async.rustscript" },
            "2": { "name": "keyword.declaration.function.rustscript" },
            "3": { "name": "entity.name.function.rustscript" },
            "4": { "name": "punctuation.definition.typeparameters.begin.rustscript" }
          }
        },
        {
          "comment": "function declaration",
          "match": "\\b(function)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(<)?",
          "captures": {
            "1": { "name": "keyword.declaration.function.rustscript" },
            "2": { "name": "entity.name.function.rustscript" },
            "3": { "name": "punctuation.definition.typeparameters.begin.rustscript" }
          }
        }
      ]
    },
    "arrow-function": {
      "patterns": [
        {
          "comment": "arrow function =>",
          "match": "=>",
          "name": "storage.type.function.arrow.rustscript"
        }
      ]
    },
    "class-declaration": {
      "match": "\\b(class)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
      "captures": {
        "1": { "name": "keyword.declaration.class.rustscript" },
        "2": { "name": "entity.name.type.class.rustscript" }
      }
    },
    "interface-declaration": {
      "match": "\\b(interface)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
      "captures": {
        "1": { "name": "keyword.declaration.interface.rustscript" },
        "2": { "name": "entity.name.type.interface.rustscript" }
      }
    },
    "type-declaration": {
      "match": "\\b(type)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(=)",
      "captures": {
        "1": { "name": "keyword.declaration.type.rustscript" },
        "2": { "name": "entity.name.type.alias.rustscript" },
        "3": { "name": "keyword.operator.assignment.rustscript" }
      }
    },
    "enum-declaration": {
      "match": "\\b(enum)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
      "captures": {
        "1": { "name": "keyword.declaration.enum.rustscript" },
        "2": { "name": "entity.name.type.enum.rustscript" }
      }
    },
    "import-export": {
      "patterns": [
        {
          "comment": "import statement",
          "begin": "\\b(import)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.module.import.rustscript" }
          },
          "end": ";|$",
          "endCaptures": {
            "0": { "name": "punctuation.terminator.statement.rustscript" }
          },
          "patterns": [
            {
              "match": "\\b(from)\\b",
              "name": "keyword.module.from.rustscript"
            },
            {
              "match": "\\b(as)\\b",
              "name": "keyword.other.as.rustscript"
            },
            { "include": "#strings" },
            {
              "match": "\\b[a-zA-Z_$][a-zA-Z0-9_$]*\\b",
              "name": "variable.other.readwrite.rustscript"
            },
            { "include": "#punctuation" }
          ]
        },
        {
          "comment": "export keyword",
          "match": "\\b(export)\\b",
          "name": "keyword.module.export.rustscript"
        }
      ]
    },
    "function-call": {
      "match": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.rustscript" }
      }
    },
    "type-annotation": {
      "patterns": [
        {
          "comment": "type annotation after colon in parameter/variable position",
          "match": ":\\s*([a-zA-Z_$][a-zA-Z0-9_$]*)(?=\\s*[,)=;{|&<>]|$)",
          "captures": {
            "1": {
              "patterns": [
                { "include": "#storage-types" },
                { "include": "#constants" },
                {
                  "match": "[a-zA-Z_$][a-zA-Z0-9_$]*",
                  "name": "entity.name.type.rustscript"
                }
              ]
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.spread.rustscript",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.optional-chaining.rustscript",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.nullish-coalescing.rustscript",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.pipe.rustscript",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.comparison.rustscript",
          "match": "(===|!==|==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.rustscript",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.rustscript",
          "match": "(\\+\\+|--|\\*\\*|\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.assignment.rustscript",
          "match": "(\\*\\*=|&&=|\\|\\|=|\\?\\?=|\\+=|-=|\\*=|/=|%=|<<=|>>=|>>>=|&=|\\|=|\\^=|=)"
        },
        {
          "name": "keyword.operator.bitwise.rustscript",
          "match": "(>>>|<<|>>|&|\\||\\^|~)"
        },
        {
          "name": "keyword.operator.ternary.rustscript",
          "match": "\\?"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.rustscript",
          "match": ","
        },
        {
          "name": "punctuation.terminator.statement.rustscript",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.rustscript",
          "match": "\\."
        },
        {
          "name": "meta.brace.curly.rustscript",
          "match": "[{}]"
        },
        {
          "name": "meta.brace.round.rustscript",
          "match": "[()]"
        },
        {
          "name": "meta.brace.square.rustscript",
          "match": "[\\[\\]]"
        }
      ]
    }
  }
}
